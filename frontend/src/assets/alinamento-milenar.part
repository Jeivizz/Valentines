                        <div class="text-sm font-medium text-text-primary truncate">KISS MY SASS <span class="text-xs text-text-muted">4 &#x43C;&#x438;&#x43D;. &#x43D;&#x430;&#x437;&#x430;&#x434;</span></div>
                        <p class="text-sm text-text-secondary truncate" title="KISS &#x2014; &#x43A;&#x443;&#x43B;&#x44C;&#x442;&#x443;&#x440;&#x43D;&#x430;&#x44F; &#x438;&#x43A;&#x43E;&#x43D;&#x430;. &#x41A; 1998 &#x433;&#x43E;&#x434;&#x443; &#x43E;&#x43D;&#x438; &#x443;&#x436;&#x435; &#x431;&#x44B;&#x43B;&#x438; &#x43B;&#x435;&#x433;&#x435;&#x43D;&#x434;&#x430;&#x43C;&#x438; &#x433;&#x43B;&#x44D;&#x43C;&#x2011;&#x43C;&#x435;&#x442;&#x430;&#x43B;&#x430; &#x438; &#x445;&#x430;&#x440;&#x434;&#x2011;&#x440;&#x43E;&#x43A;&#x430;, &#x437;&#x430;&#x434;&#x430;&#x432;&#x448;&#x438;&#x43C;&#x438; &#x441;&#x442;&#x430;&#x43D;&#x434;&#x430;&#x440;&#x442;&#x44B; &#x441;&#x446;&#x435;&#x43D;&#x438;&#x447;&#x435;&#x441;&#x43A;&#x43E;&#x433;&#x43E; &#x448;&#x43E;&#x443;, &#x438;&#x43C;&#x438;&#x434;&#x436;&#x430; &#x438; &#x44D;&#x43D;&#x435;&#x440;&#x433;&#x438;&#x447;&#x43D;&#x43E;&#x433;&#x43E; &#x437;&#x432;&#x443;&#x447;&#x430;&#x43D;&#x438;&#x44F;. &#x410;&#x43B;&#x44C;&#x431;&#x43E;&#x43C; &#xAB;Psycho Circus&#xBB; &#x441;&#x442;&#x430;&#x43B; &#x442;&#x440;&#x438;&#x443;&#x43C;&#x444;&#x430;&#x43B;&#x44C;&#x43D;&#x44B;&#x43C; &#x440;&#x435;&#x44E;&#x43D;&#x44C;&#x43E;&#x43D;&#x43E;&#x43C; &#x438; &#x432;&#x43E;&#x437;&#x432;&#x440;&#x430;&#x449;&#x435;&#x43D;&#x438;&#x435;&#x43C; &#x43A; &#x43A;&#x43E;&#x440;&#x43D;&#x44F;&#x43C;: &#x43C;&#x443;&#x437;&#x44B;&#x43A;&#x430;&#x43D;&#x442;&#x44B; &#x432;&#x43D;&#x43E;&#x432;&#x44C; &#x43D;&#x430;&#x43D;&#x435;&#x441;&#x43B;&#x438; &#x433;&#x440;&#x438;&#x43C;, &#x430; &#x43C;&#x443;&#x437;&#x44B;&#x43A;&#x430; &#x43E;&#x431;&#x440;&#x435;&#x43B;&#x430; &#x43F;&#x440;&#x435;&#x436;&#x43D;&#x44E;&#x44E; &#x43C;&#x43E;&#x449;&#x44C;. &#x413;&#x440;&#x443;&#x43F;&#x43F;&#x430; &#x434;&#x43E;&#x43A;&#x430;&#x437;&#x430;&#x43B;&#x430;, &#x447;&#x442;&#x43E; &#x43C;&#x43E;&#x436;&#x435;&#x442; &#x441;&#x43E;&#x447;&#x435;&#x442;&#x430;&#x442;&#x44C; &#x442;&#x435;&#x430;&#x442;&#x440;&#x430;&#x43B;&#x44C;&#x43D;&#x43E;&#x441;&#x442;&#x44C; 70&#x2011;&#x445; &#x441; &#x441;&#x43E;&#x432;&#x440;&#x435;&#x43C;&#x435;&#x43D;&#x43D;&#x44B;&#x43C; &#x437;&#x432;&#x443;&#x43A;&#x43E;&#x43C; 90&#x2011;&#x445;. &#x421;&#x438;&#x43D;&#x433;&#x43B; &#xAB;I Finally Found My Way&#xBB; &#x441; &#x430;&#x43B;&#x44C;&#x431;&#x43E;&#x43C;&#x430; &#xAB;Psycho Circus&#xBB; &#x431;&#x44B;&#x43B; &#x442;&#x440;&#x435;&#x442;&#x44C;&#x438;&#x43C; &#x43F;&#x43E; &#x441;&#x447;&#x451;&#x442;&#x443; &#x438; &#x432;&#x44B;&#x43F;&#x443;&#x449;&#x435;&#x43D; &#x432; &#x43D;&#x43E;&#x44F;&#x431;&#x440;&#x435; 1998 &#x433;&#x43E;&#x434;&#x430;. &#xAB;I Finally Found My Way&#xBB; &#x2014; &#x43F;&#x440;&#x43E;&#x43D;&#x437;&#x438;&#x442;&#x435;&#x43B;&#x44C;&#x43D;&#x430;&#x44F;, &#x44D;&#x43C;&#x43E;&#x446;&#x438;&#x43E;&#x43D;&#x430;&#x43B;&#x44C;&#x43D;&#x43E; &#x437;&#x430;&#x440;&#x44F;&#x436;&#x435;&#x43D;&#x43D;&#x430;&#x44F; &#x431;&#x430;&#x43B;&#x43B;&#x430;&#x434;&#x430;, &#x43A;&#x43E;&#x442;&#x43E;&#x440;&#x430;&#x44F; &#x440;&#x430;&#x441;&#x43A;&#x440;&#x44B;&#x432;&#x430;&#x435;&#x442; &#x43D;&#x43E;&#x432;&#x443;&#x44E; &#x433;&#x440;&#x430;&#x43D;&#x44C; &#x43C;&#x43E;&#x449;&#x438; KISS. &#x42D;&#x442;&#x43E; &#x43D;&#x435; &#x43F;&#x440;&#x43E;&#x441;&#x442;&#x43E; &#x442;&#x440;&#x435;&#x43A;, &#x430; &#x438;&#x441;&#x43F;&#x43E;&#x432;&#x435;&#x434;&#x44C; &#x434;&#x443;&#x448;&#x438;, &#x43E;&#x431;&#x43B;&#x435;&#x447;&#x451;&#x43D;&#x43D;&#x430;&#x44F; &#x432; &#x440;&#x43E;&#x441;&#x43A;&#x43E;&#x448;&#x43D;&#x443;&#x44E; &#x43C;&#x443;&#x437;&#x44B;&#x43A;&#x430;&#x43B;&#x44C;&#x43D;&#x443;&#x44E; &#x444;&#x43E;&#x440;&#x43C;&#x443;. &#x41F;&#x435;&#x441;&#x43D;&#x44F; &#x434;&#x43E;&#x43A;&#x430;&#x437;&#x44B;&#x432;&#x430;&#x435;&#x442;, &#x447;&#x442;&#x43E; KISS &#x443;&#x43C;&#x435;&#x44E;&#x442; &#x431;&#x44B;&#x442;&#x44C; &#x43D;&#x435; &#x442;&#x43E;&#x43B;&#x44C;&#x43A;&#x43E; &#x433;&#x440;&#x43E;&#x43C;&#x43E;&#x433;&#x43B;&#x430;&#x441;&#x43D;&#x44B;&#x43C;&#x438;, &#x43D;&#x43E; &#x438; &#x433;&#x43B;&#x443;&#x431;&#x43E;&#x43A;&#x43E; &#x43B;&#x438;&#x440;&#x438;&#x447;&#x43D;&#x44B;&#x43C;&#x438;. &#x416;&#x430;&#x43D;&#x440;&#x43E;&#x432;&#x44B;&#x439; &#x441;&#x442;&#x438;&#x43B;&#x44C;: &#x416;&#x430;&#x43D;&#x440;: &#x441;&#x438;&#x43C;&#x444;&#x43E;&#x43D;&#x438;&#x447;&#x435;&#x441;&#x43A;&#x430;&#x44F; &#x431;&#x430;&#x43B;&#x43B;&#x430;&#x434;&#x430;, &#x445;&#x430;&#x440;&#x434;&#x2011;&#x440;&#x43E;&#x43A; &#x441; &#x44D;&#x43B;&#x435;&#x43C;&#x435;&#x43D;&#x442;&#x430;&#x43C;&#x438; &#x430;&#x440;&#x435;&#x43D;&#x430;&#x2011;&#x440;&#x43E;&#x43A;&#x430;. &#x423;&#x447;&#x430;&#x441;&#x442;&#x43D;&#x438;&#x43A;&#x438; &#x437;&#x430;&#x43F;&#x438;&#x441;&#x438; &#x438; &#x438;&#x445; &#x432;&#x43A;&#x43B;&#x430;&#x434;: &#x41F;&#x438;&#x442;&#x435;&#x440; &#x41A;&#x440;&#x438;&#x441;&#x441; (Peter Criss) &#x2014; &#x432;&#x43E;&#x43A;&#x430;&#x43B; &#x2014; &#x435;&#x433;&#x43E; &#x43F;&#x440;&#x43E;&#x43D;&#x438;&#x43A;&#x43D;&#x43E;&#x432;&#x435;&#x43D;&#x43D;&#x43E;&#x435; &#x438;&#x441;&#x43F;&#x43E;&#x43B;&#x43D;&#x435;&#x43D;&#x438;&#x435;, &#x441; &#x444;&#x438;&#x440;&#x43C;&#x435;&#x43D;&#x43D;&#x44B;&#x43C; &#x430;&#x43A;&#x446;&#x435;&#x43D;&#x442;&#x43E;&#x43C; &#x43D;&#x430; &#x44D;&#x43C;&#x43E;&#x446;&#x438;&#x43E;&#x43D;&#x430;&#x43B;&#x44C;&#x43D;&#x443;&#x44E; &#x43F;&#x43E;&#x434;&#x430;&#x447;&#x443; &#x43B;&#x438;&#x440;&#x438;&#x43A;&#x438;, &#x43D;&#x430;&#x43F;&#x43E;&#x43B;&#x43D;&#x44F;&#x435;&#x442; &#x442;&#x440;&#x435;&#x43A; &#x43F;&#x43E;&#x434;&#x43B;&#x438;&#x43D;&#x43D;&#x43E;&#x439; &#x438;&#x441;&#x43A;&#x440;&#x435;&#x43D;&#x43D;&#x43E;&#x441;&#x442;&#x44C;&#x44E;; &#x41F;&#x43E;&#x43B; &#x421;&#x442;&#x44D;&#x43D;&#x43B;&#x438; (Paul Stanley) &#x2014; &#x430;&#x43A;&#x443;&#x441;&#x442;&#x438;&#x447;&#x435;&#x441;&#x43A;&#x430;&#x44F; &#x433;&#x438;&#x442;&#x430;&#x440;&#x430;, &#x431;&#x44D;&#x43A;-&#x432;&#x43E;&#x43A;&#x430;&#x43B;, &#x433;&#x43B;&#x430;&#x432;&#x43D;&#x44B;&#x439; &#x430;&#x432;&#x442;&#x43E;&#x440; &#x43F;&#x435;&#x441;&#x43D;&#x438; &#x2014; &#x441;&#x43E;&#x437;&#x434;&#x430;&#x451;&#x442; &#x442;&#x451;&#x43F;&#x43B;&#x43E;&#x435;, &#x43C;&#x435;&#x43B;&#x43E;&#x434;&#x438;&#x447;&#x43D;&#x43E;&#x435; &#x441;&#x43E;&#x43F;&#x440;&#x43E;&#x432;&#x43E;&#x436;&#x434;&#x435;&#x43D;&#x438;&#x435;, &#x43A;&#x43E;&#x442;&#x43E;&#x440;&#x43E;&#x435; &#x441;&#x442;&#x430;&#x43B;&#x43E; &#x43E;&#x441;&#x43D;&#x43E;&#x432;&#x43E;&#x439; &#x434;&#x43B;&#x44F; &#x43B;&#x438;&#x440;&#x438;&#x447;&#x43D;&#x43E;&#x439; &#x431;&#x430;&#x43B;&#x43B;&#x430;&#x434;&#x44B;. &#x41E;&#x43D; &#x43F;&#x43E;&#x434;&#x434;&#x435;&#x440;&#x436;&#x430;&#x43B; &#x432;&#x43E;&#x43A;&#x430;&#x43B; &#x41A;&#x440;&#x438;&#x441;&#x441;&#x430; &#x433;&#x430;&#x440;&#x43C;&#x43E;&#x43D;&#x438;&#x447;&#x43D;&#x44B;&#x43C;&#x438; &#x431;&#x44D;&#x43A;-&#x432;&#x43E;&#x43A;&#x430;&#x43B;&#x44C;&#x43D;&#x44B;&#x43C;&#x438; &#x43F;&#x430;&#x440;&#x442;&#x438;&#x44F;&#x43C;&#x438;; Bruce Kulick (&#x411;&#x440;&#x44E;&#x441; &#x41A;&#x443;&#x43B;&#x438;&#x43A;) &#x2014; &#x431;&#x430;&#x441;&#x2011;&#x433;&#x438;&#x442;&#x430;&#x440;&#x430; &#x2014; &#x437;&#x432;&#x443;&#x447;&#x438;&#x442; &#x440;&#x43E;&#x432;&#x43D;&#x43E; &#x438; &#x43C;&#x44F;&#x433;&#x43A;&#x43E;, &#x441; &#x440;&#x438;&#x442;&#x43C;&#x43E;&#x43C; &#x438; &#x43F;&#x43E;&#x434;&#x434;&#x435;&#x440;&#x436;&#x43A;&#x43E;&#x439; &#x432;&#x43E;&#x43A;&#x430;&#x43B;&#x430; &#x41A;&#x440;&#x438;&#x441;&#x441;&#x430;, &#x441;&#x43E;&#x437;&#x434;&#x430;&#x432;&#x430;&#x44F; &#x443;&#x441;&#x442;&#x43E;&#x439;&#x447;&#x438;&#x432;&#x44B;&#x439; &#x433;&#x440;&#x443;&#x432; &#x438; &#x433;&#x430;&#x440;&#x43C;&#x43E;&#x43D;&#x438;&#x447;&#x435;&#x441;&#x43A;&#x443;&#x44E; &#x43E;&#x441;&#x43D;&#x43E;&#x432;&#x443; &#x434;&#x43B;&#x44F; &#x43C;&#x435;&#x43B;&#x43E;&#x434;&#x438;&#x438;; &#x41A;&#x435;&#x432;&#x438;&#x43D; &#x412;&#x430;&#x43B;&#x435;&#x43D;&#x442;&#x430;&#x439;&#x43D; (Kevin Valentine) &#x2014; &#x443;&#x434;&#x430;&#x440;&#x43D;&#x44B;&#x435; &#x2014; &#x447;&#x451;&#x442;&#x43A;&#x430;&#x44F;, &#x441;&#x434;&#x435;&#x440;&#x436;&#x430;&#x43D;&#x43D;&#x430;&#x44F; &#x438;&#x433;&#x440;&#x430; &#x43F;&#x43E;&#x434;&#x447;&#x451;&#x440;&#x43A;&#x438;&#x432;&#x430;&#x435;&#x442; &#x434;&#x440;&#x430;&#x43C;&#x430;&#x442;&#x438;&#x437;&#x43C; &#x43F;&#x435;&#x441;&#x43D;&#x438;, &#x43D;&#x435; &#x43E;&#x442;&#x432;&#x43B;&#x435;&#x43A;&#x430;&#x44F; &#x43E;&#x442; &#x432;&#x43E;&#x43A;&#x430;&#x43B;&#x430;; &#x428;&#x435;&#x43B;&#x43B;&#x438; &#x411;&#x435;&#x440;&#x433; (Shelly Berg) &#x2014; &#x430;&#x43A;&#x443;&#x441;&#x442;&#x438;&#x447;&#x435;&#x441;&#x43A;&#x43E;&#x435; &#x43F;&#x438;&#x430;&#x43D;&#x438;&#x43D;&#x43E;, &#x43E;&#x440;&#x43A;&#x435;&#x441;&#x442;&#x440;&#x43E;&#x432;&#x43A;&#x430;, &#x434;&#x438;&#x440;&#x438;&#x436;&#x451;&#x440;. &#x420;&#x43E;&#x441;&#x43A;&#x43E;&#x448;&#x43D;&#x44B;&#x435; &#x444;&#x43E;&#x440;&#x442;&#x435;&#x43F;&#x438;&#x430;&#x43D;&#x43D;&#x44B;&#x435; &#x43B;&#x438;&#x43D;&#x438;&#x438; &#x438; &#x43E;&#x440;&#x43A;&#x435;&#x441;&#x442;&#x440;&#x43E;&#x432;&#x44B;&#x435; &#x430;&#x440;&#x430;&#x43D;&#x436;&#x438;&#x440;&#x43E;&#x432;&#x43A;&#x438; &#x43F;&#x440;&#x435;&#x432;&#x440;&#x430;&#x449;&#x430;&#x44E;&#x442; &#x431;&#x430;&#x43B;&#x43B;&#x430;&#x434;&#x443; &#x432; &#x43B;&#x430;&#x43A;&#x43E;&#x43D;&#x438;&#x447;&#x43D;&#x443;&#x44E;, &#x438;&#x437;&#x44F;&#x449;&#x43D;&#x443;&#x44E; &#x441;&#x438;&#x43C;&#x444;&#x43E;&#x43D;&#x438;&#x44E;; &#x411;&#x43E;&#x431; &#x42D;&#x437;&#x440;&#x438;&#x43D; (Bob Ezrin) &#x2014; Fender Rhodes (&#x44D;&#x43B;&#x435;&#x43A;&#x442;&#x440;&#x438;&#x447;&#x435;&#x441;&#x43A;&#x43E;&#x435; &#x43F;&#x438;&#x430;&#x43D;&#x438;&#x43D;&#x43E;), &#x441;&#x43E;&#x430;&#x432;&#x442;&#x43E;&#x440; &#x43F;&#x435;&#x441;&#x43D;&#x438;. &#x415;&#x433;&#x43E; &#x43A;&#x43B;&#x430;&#x432;&#x438;&#x448;&#x43D;&#x44B;&#x435; &#x43F;&#x435;&#x440;&#x435;&#x43B;&#x438;&#x432;&#x44B; &#x434;&#x43E;&#x431;&#x430;&#x432;&#x43B;&#x44F;&#x44E;&#x442; &#x442;&#x440;&#x435;&#x43A;&#x443; &#x430;&#x442;&#x43C;&#x43E;&#x441;&#x444;&#x435;&#x440;&#x43D;&#x43E;&#x441;&#x442;&#x438; &#x438; &#x433;&#x43B;&#x443;&#x431;&#x438;&#x43D;&#x44B;. &#x421;&#x430;&#x43C; &#x421;&#x442;&#x44D;&#x43D;&#x43B;&#x438; &#x440;&#x430;&#x441;&#x441;&#x43A;&#x430;&#x437;&#x44B;&#x432;&#x430;&#x43B;, &#x447;&#x442;&#x43E; &#x440;&#x430;&#x431;&#x43E;&#x442;&#x430;&#x43B; &#x43D;&#x430;&#x434; &#x43F;&#x435;&#x441;&#x43D;&#x435;&#x439; &#x432;&#x43C;&#x435;&#x441;&#x442;&#x435; &#x441; &#x43F;&#x440;&#x43E;&#x434;&#x44E;&#x441;&#x435;&#x440;&#x43E;&#x43C; &#x42D;&#x437;&#x440;&#x438;&#x43D;&#x43E;&#x43C;. &#x41E;&#x43D;&#x438; &#x446;&#x435;&#x43B;&#x435;&#x43D;&#x430;&#x43F;&#x440;&#x430;&#x432;&#x43B;&#x435;&#x43D;&#x43D;&#x43E; &#x43F;&#x438;&#x441;&#x430;&#x43B;&#x438; &#x43A;&#x43E;&#x43C;&#x43F;&#x43E;&#x437;&#x438;&#x446;&#x438;&#x44E;, &#x43A;&#x43E;&#x442;&#x43E;&#x440;&#x430;&#x44F; &#x431;&#x44B; &#x438;&#x434;&#x435;&#x430;&#x43B;&#x44C;&#x43D;&#x43E; &#x43F;&#x43E;&#x434;&#x43E;&#x448;&#x43B;&#x430; &#x433;&#x43E;&#x43B;&#x43E;&#x441;&#x443; &#x438; &#x441;&#x442;&#x438;&#x43B;&#x44E; &#x41A;&#x440;&#x438;&#x441;&#x441;&#x430;. &#x421;&#x442;&#x44D;&#x43D;&#x43B;&#x438; &#x432;&#x441;&#x43F;&#x43E;&#x43C;&#x438;&#x43D;&#x430;&#x43B;, &#x447;&#x442;&#x43E; &#x41A;&#x440;&#x438;&#x441;&#x441;, &#x443;&#x441;&#x43B;&#x44B;&#x448;&#x430;&#x432; &#x434;&#x435;&#x43C;&#x43E;&#x432;&#x435;&#x440;&#x441;&#x438;&#x44E; &#x441; &#x435;&#x433;&#x43E; &#x441;&#x43E;&#x431;&#x441;&#x442;&#x432;&#x435;&#x43D;&#x43D;&#x44B;&#x43C; &#x432;&#x43E;&#x43A;&#x430;&#x43B;&#x43E;&#x43C;, &#x442;&#x449;&#x430;&#x442;&#x435;&#x43B;&#x44C;&#x43D;&#x43E; &#x440;&#x430;&#x437;&#x443;&#x447;&#x438;&#x43B; &#x43F;&#x430;&#x440;&#x442;&#x438;&#x44E; &#x438;, &#x432; &#x441;&#x432;&#x43E;&#x44E; &#x43E;&#x447;&#x435;&#x440;&#x435;&#x434;&#x44C;, &#x441;&#x435;&#x440;&#x44C;&#x451;&#x437;&#x43D;&#x43E; &#x43E;&#x442;&#x43D;&#x451;&#x441;&#x441;&#x44F; &#x43A; &#x437;&#x430;&#x43F;&#x438;&#x441;&#x438;, &#x441;&#x442;&#x430;&#x440;&#x430;&#x44F;&#x441;&#x44C; &#x438;&#x441;&#x43F;&#x43E;&#x43B;&#x43D;&#x438;&#x442;&#x44C; &#x43F;&#x430;&#x440;&#x442;&#x438;&#x44E; &#x43A;&#x430;&#x43A; &#x43C;&#x43E;&#x436;&#x43D;&#x43E; &#x43B;&#x443;&#x447;&#x448;&#x435;. &#xAB;I Finally Found My Way&#xBB; &#x441;&#x442;&#x430;&#x43B;&#x430; &#x441;&#x432;&#x43E;&#x435;&#x43E;&#x431;&#x440;&#x430;&#x437;&#x43D;&#x44B;&#x43C; &#x434;&#x443;&#x445;&#x43E;&#x432;&#x43D;&#x44B;&#x43C; &#x43F;&#x440;&#x435;&#x435;&#x43C;&#x43D;&#x438;&#x43A;&#x43E;&#x43C; &#xAB;Beth&#xBB; (1976) &#x2014; &#x435;&#x449;&#x451; &#x43E;&#x434;&#x43D;&#x43E;&#x439; &#x437;&#x43D;&#x430;&#x43A;&#x43E;&#x432;&#x43E;&#x439; &#x445;&#x438;&#x442;&#x43E;&#x432;&#x43E;&#x439; &#x431;&#x430;&#x43B;&#x43B;&#x430;&#x434;&#x43E;&#x439;, &#x433;&#x434;&#x435; &#x41A;&#x440;&#x438;&#x441;&#x441; &#x432;&#x44B;&#x441;&#x442;&#x443;&#x43F;&#x438;&#x43B; &#x432;&#x43E;&#x43A;&#x430;&#x43B;&#x438;&#x441;&#x442;&#x43E;&#x43C;. &#x411;&#x435;&#x437;&#x443;&#x43F;&#x440;&#x435;&#x447;&#x43D;&#x43E;&#x435; &#x43A;&#x430;&#x447;&#x435;&#x441;&#x442;&#x432;&#x43E; &#x437;&#x432;&#x443;&#x43A;&#x430;: &#x447;&#x438;&#x441;&#x442;&#x44B;&#x439; &#x432;&#x43E;&#x43A;&#x430;&#x43B;, &#x434;&#x435;&#x442;&#x430;&#x43B;&#x44C;&#x43D;&#x43E; &#x43F;&#x440;&#x43E;&#x440;&#x430;&#x431;&#x43E;&#x442;&#x430;&#x43D;&#x43D;&#x44B;&#x435; &#x438;&#x43D;&#x441;&#x442;&#x440;&#x443;&#x43C;&#x435;&#x43D;&#x442;&#x44B;, &#x433;&#x430;&#x440;&#x43C;&#x43E;&#x43D;&#x438;&#x447;&#x43D;&#x43E;&#x435; &#x441;&#x432;&#x435;&#x434;&#x435;&#x43D;&#x438;&#x435;. &#x41E;&#x440;&#x43A;&#x435;&#x441;&#x442;&#x440;&#x43E;&#x432;&#x43A;&#x430; &#x437;&#x432;&#x443;&#x447;&#x438;&#x442; &#x435;&#x441;&#x442;&#x435;&#x441;&#x442;&#x432;&#x435;&#x43D;&#x43D;&#x43E;, &#x43D;&#x435; &#x437;&#x430;&#x442;&#x43C;&#x435;&#x432;&#x430;&#x44F; &#x43E;&#x441;&#x43D;&#x43E;&#x432;&#x43D;&#x43E;&#x439; &#x432;&#x43E;&#x43A;&#x430;&#x43B;. &#x41F;&#x440;&#x43E;&#x43C;&#x43E;-&#x441;&#x438;&#x43D;&#x433;&#x43B; &#xAB;I Finally Found My Way&#xBB; &#x433;&#x440;&#x443;&#x43F;&#x43F;&#x44B; KISS &#x434;&#x43E;&#x431;&#x438;&#x43B;&#x441;&#x44F; &#x437;&#x430;&#x43C;&#x435;&#x442;&#x43D;&#x43E;&#x433;&#x43E; &#x443;&#x441;&#x43F;&#x435;&#x445;&#x430;: &#x43E;&#x43D; &#x430;&#x43A;&#x442;&#x438;&#x432;&#x43D;&#x43E; &#x440;&#x43E;&#x442;&#x438;&#x440;&#x43E;&#x432;&#x430;&#x43B;&#x441;&#x44F; &#x43D;&#x430; &#x440;&#x430;&#x434;&#x438;&#x43E;&#x441;&#x442;&#x430;&#x43D;&#x446;&#x438;&#x44F;&#x445; &#x432; &#x421;&#x428;&#x410; &#x438; &#x415;&#x432;&#x440;&#x43E;&#x43F;&#x435;, &#x437;&#x430;&#x432;&#x43E;&#x435;&#x432;&#x430;&#x432; &#x441;&#x435;&#x440;&#x434;&#x446;&#x430; &#x43A;&#x430;&#x43A; &#x43F;&#x43E;&#x43A;&#x43B;&#x43E;&#x43D;&#x43D;&#x438;&#x43A;&#x43E;&#x432; &#x433;&#x440;&#x443;&#x43F;&#x43F;&#x44B;, &#x442;&#x430;&#x43A; &#x438; &#x43B;&#x44E;&#x431;&#x438;&#x442;&#x435;&#x43B;&#x435;&#x439; &#x440;&#x43E;&#x43A;-&#x431;&#x430;&#x43B;&#x43B;&#x430;&#x434;. &#x41F;&#x43E;&#x44F;&#x432;&#x438;&#x432;&#x448;&#x438;&#x441;&#x44C; &#x432; &#x430;&#x43B;&#x44C;&#x431;&#x43E;&#x43C;&#x435;- &#x440;&#x435;&#x44E;&#x43D;&#x44C;&#x43E;&#x43D;&#x435; KISS &#xAB;Psycho Circus&#xBB;, &#x438;&#x437;&#x432;&#x435;&#x441;&#x442;&#x43D;&#x44B;&#x445; &#x43A;&#x430;&#x43A; &#x430;&#x433;&#x440;&#x435;&#x441;&#x441;&#x438;&#x432;&#x43D;&#x44B;&#x435; &#x438;&#x441;&#x43F;&#x43E;&#x43B;&#x43D;&#x438;&#x442;&#x435;&#x43B;&#x438;, &#x431;&#x430;&#x43B;&#x43B;&#x430;&#x434;&#x430; &#xAB;I Finally Found My Way&#xBB; &#x441;&#x442;&#x430;&#x43B;&#x430; &#x43D;&#x430;&#x441;&#x442;&#x43E;&#x44F;&#x449;&#x438;&#x43C; &#x43F;&#x440;&#x438;&#x44F;&#x442;&#x43D;&#x44B;&#x43C; &#x441;&#x44E;&#x440;&#x43F;&#x440;&#x438;&#x437;&#x43E;&#x43C;. &#x423;&#x441;&#x43F;&#x435;&#x445; &#x441;&#x438;&#x43D;&#x433;&#x43B;&#x430; &#x43F;&#x43E;&#x43C;&#x43E;&#x433; &#x430;&#x43B;&#x44C;&#x431;&#x43E;&#x43C;&#x443; &#xAB;Psycho Circus&#xBB; &#x43F;&#x43E;&#x43A;&#x430;&#x437;&#x430;&#x442;&#x44C; &#x441;&#x438;&#x43B;&#x44C;&#x43D;&#x44B;&#x435; &#x440;&#x435;&#x437;&#x443;&#x43B;&#x44C;&#x442;&#x430;&#x442;&#x44B;: &#x437;&#x430;&#x43D;&#x44F;&#x442;&#x44C; &#x2014; 3 &#x43C;&#x435;&#x441;&#x442;&#x43E; &#x432; Billboard 200 &#x421;&#x428;&#x410;, 2 &#x43C;&#x435;&#x441;&#x442;&#x43E; &#x432; Rock &amp; Metal Singles Chart &#x438; Rock &amp; Metal Albums Chart &#x412;&#x435;&#x43B;&#x438;&#x43A;&#x43E;&#x431;&#x440;&#x438;&#x442;&#x430;&#x43D;&#x438;&#x438; &#x438; &#x43F;&#x43E;&#x43F;&#x430;&#x441;&#x442;&#x44C; &#x432; &#x442;&#x43E;&#x43F;&#x2011;5 &#x43D;&#x430;&#x446;&#x438;&#x43E;&#x43D;&#x430;&#x43B;&#x44C;&#x43D;&#x44B;&#x445; &#x447;&#x430;&#x440;&#x442;&#x43E;&#x432; &#x431;&#x43E;&#x43B;&#x44C;&#x448;&#x438;&#x43D;&#x441;&#x442;&#x432;&#x430; &#x441;&#x442;&#x440;&#x430;&#x43D; &#x415;&#x432;&#x440;&#x43E;&#x43F;&#x44B;. &#x418;&#x442;&#x43E;&#x433;: &#x41F;&#x440;&#x43E;&#x43C;&#x43E;-&#x441;&#x438;&#x43D;&#x433;&#x43B; &#xAB;I Finally Found My Way&#xBB; &#x2014; &#x44D;&#x442;&#x43E; &#x433;&#x438;&#x43C;&#x43D; &#x43E;&#x431;&#x440;&#x435;&#x442;&#x451;&#x43D;&#x43D;&#x43E;&#x439; &#x43D;&#x430;&#x434;&#x435;&#x436;&#x434;&#x44B;, &#x440;&#x430;&#x441;&#x43A;&#x440;&#x44B;&#x432;&#x430;&#x44E;&#x449;&#x438;&#x439; KISS &#x441; &#x44D;&#x43C;&#x43E;&#x446;&#x438;&#x43E;&#x43D;&#x430;&#x43B;&#x44C;&#x43D;&#x43E;&#x439; &#x441;&#x442;&#x43E;&#x440;&#x43E;&#x43D;&#x44B;. &#x42D;&#x442;&#x430; &#x43F;&#x440;&#x435;&#x43A;&#x440;&#x430;&#x441;&#x43D;&#x430;&#x44F; &#x431;&#x430;&#x43B;&#x43B;&#x430;&#x434;&#x430; &#x43E;&#x431;&#x43B;&#x430;&#x434;&#x430;&#x435;&#x442; &#x432;&#x441;&#x435;&#x43C;&#x438; &#x438;&#x43D;&#x433;&#x440;&#x435;&#x434;&#x438;&#x435;&#x43D;&#x442;&#x430;&#x43C;&#x438; &#x43D;&#x430;&#x441;&#x442;&#x43E;&#x44F;&#x449;&#x435;&#x433;&#x43E; &#x445;&#x438;&#x442;&#x430;: &#x441;&#x438;&#x43B;&#x44C;&#x43D;&#x44B;&#x43C; &#x432;&#x43E;&#x43A;&#x430;&#x43B;&#x43E;&#x43C; &#x41F;&#x438;&#x442;&#x435;&#x440;&#x430; &#x41A;&#x440;&#x438;&#x441;&#x441;&#x430;, &#x437;&#x430;&#x43F;&#x43E;&#x43C;&#x438;&#x43D;&#x430;&#x44E;&#x449;&#x435;&#x439;&#x441;&#x44F; &#x43C;&#x435;&#x43B;&#x43E;&#x434;&#x438;&#x435;&#x439;, &#x44D;&#x43C;&#x43E;&#x446;&#x438;&#x43E;&#x43D;&#x430;&#x43B;&#x44C;&#x43D;&#x43E;&#x439; &#x433;&#x43B;&#x443;&#x431;&#x438;&#x43D;&#x43E;&#x439; &#x438; &#x443;&#x43D;&#x438;&#x432;&#x435;&#x440;&#x441;&#x430;&#x43B;&#x44C;&#x43D;&#x44B;&#x43C; &#x43F;&#x43E;&#x441;&#x43B;&#x430;&#x43D;&#x438;&#x435;&#x43C;. &#xAB;I Finally Found My Way&#xBB; &#x437;&#x430;&#x43D;&#x44F;&#x43B;&#x430; &#x43F;&#x43E;&#x447;&#x451;&#x442;&#x43D;&#x43E;&#x435; &#x43C;&#x435;&#x441;&#x442;&#x43E; &#x432; &#x438;&#x441;&#x442;&#x43E;&#x440;&#x438;&#x438; &#x440;&#x43E;&#x43A;&#x2011;&#x431;&#x430;&#x43B;&#x43B;&#x430;&#x434; &#x438; &#x441;&#x442;&#x430;&#x43B;&#x430; &#x435;&#x449;&#x451; &#x43E;&#x434;&#x43D;&#x43E;&#x439; &#x437;&#x43D;&#x430;&#x43A;&#x43E;&#x432;&#x43E;&#x439; &#x43A;&#x43E;&#x43C;&#x43F;&#x43E;&#x437;&#x438;&#x446;&#x438;&#x435;&#x439; &#x432; &#x434;&#x438;&#x441;&#x43A;&#x43E;&#x433;&#x440;&#x430;&#x444;&#x438;&#x438; KISS &#x2014; &#x432;&#x430;&#x436;&#x43D;&#x43E;&#x439; &#x447;&#x430;&#x441;&#x442;&#x44C;&#x44E; &#x43D;&#x430;&#x441;&#x43B;&#x435;&#x434;&#x438;&#x44F; &#x433;&#x440;&#x443;&#x43F;&#x43F;&#x44B;, &#x434;&#x435;&#x43C;&#x43E;&#x43D;&#x441;&#x442;&#x440;&#x438;&#x440;&#x443;&#x44F; &#x435;&#x451; &#x441;&#x43F;&#x43E;&#x441;&#x43E;&#x431;&#x43D;&#x43E;&#x441;&#x442;&#x44C; &#x43A; &#x44D;&#x43C;&#x43E;&#x446;&#x438;&#x43E;&#x43D;&#x430;&#x43B;&#x44C;&#x43D;&#x43E;&#x439; &#x433;&#x43B;&#x443;&#x431;&#x438;&#x43D;&#x435;. &#x422;&#x435;&#x43C; &#x431;&#x43E;&#x43B;&#x435;&#x435;, &#x434;&#x43B;&#x44F; &#x43F;&#x43E;&#x43A;&#x43B;&#x43E;&#x43D;&#x43D;&#x438;&#x43A;&#x43E;&#x432; &#x433;&#x440;&#x443;&#x43F;&#x43F;&#x44B;, &#x43E;&#x43D;&#x430; &#x443;&#x436;&#x435; &#x44F;&#x432;&#x43B;&#x44F;&#x435;&#x442;&#x441;&#x44F; &#x434;&#x443;&#x445;&#x43E;&#x432;&#x43D;&#x44B;&#x43C; &#x43F;&#x440;&#x435;&#x435;&#x43C;&#x43D;&#x438;&#x43A;&#x43E;&#x43C; &#xAB;Beth&#xBB;, &#x438; &#x44D;&#x442;&#x43E; &#x43C;&#x43D;&#x435;&#x43D;&#x438;&#x435; &#x431;&#x43E;&#x43B;&#x435;&#x435; &#x447;&#x435;&#x43C; &#x43E;&#x43F;&#x440;&#x430;&#x432;&#x434;&#x430;&#x43D;&#x43E;. &#x41E;&#x440;&#x438;&#x433;&#x438;&#x43D;&#x430;&#x43B; &#x43E;&#x441;&#x442;&#x430;&#x451;&#x442;&#x441;&#x44F; &#x44D;&#x442;&#x430;&#x43B;&#x43E;&#x43D;&#x43E;&#x43C;, &#x43A;&#x43E;&#x442;&#x43E;&#x440;&#x44B;&#x439; &#x43D;&#x435; &#x43D;&#x443;&#x436;&#x434;&#x430;&#x435;&#x442;&#x441;&#x44F; &#x432; &#x440;&#x430;&#x434;&#x438;&#x43E;&#x2011;&#x440;&#x435;&#x434;&#x430;&#x43A;&#x446;&#x438;&#x438; &#x434;&#x43B;&#x44F; &#x440;&#x430;&#x441;&#x448;&#x438;&#x440;&#x435;&#x43D;&#x438;&#x44F; &#x430;&#x443;&#x434;&#x438;&#x442;&#x43E;&#x440;&#x438;&#x438;. &#x42D;&#x442;&#x43E;&#x442; &#x441;&#x438;&#x43D;&#x433;&#x43B; &#x2014; &#x43F;&#x440;&#x43E;&#x432;&#x43E;&#x437;&#x433;&#x43B;&#x430;&#x448;&#x435;&#x43D;&#x438;&#x435;: KISS &#x43F;&#x43E;&#x2011;&#x43F;&#x440;&#x435;&#x436;&#x43D;&#x435;&#x43C;&#x443; &#x43D;&#x430; &#x432;&#x435;&#x440;&#x448;&#x438;&#x43D;&#x435;, &#x438;&#x445; &#x43B;&#x438;&#x440;&#x438;&#x447;&#x43D;&#x430;&#x44F; &#x44D;&#x43D;&#x435;&#x440;&#x433;&#x438;&#x44F; &#x43D;&#x435; &#x443;&#x433;&#x430;&#x441;&#x43B;&#x430;, &#x430; &#x442;&#x430;&#x43B;&#x430;&#x43D;&#x442; &#x2014; &#x43D;&#x435;&#x43F;&#x440;&#x435;&#x432;&#x437;&#x43E;&#x439;&#x434;&#x451;&#x43D;! :113-kiss-2: :019-tongue-4:">KISS — культурная икона. К 1998 году они уже были легендами глэм‑метала и хард‑рока, задавшими стандарты сценического шоу, имиджа и энергичного звучания. Альбом «Psycho Circus» стал триумфальным реюньоном и возвращением к корням: музыканты вновь нанесли грим, а музыка обрела прежнюю мощь. Группа доказала, что может сочетать театральность 70‑х с современным звуком 90‑х. Сингл «I Finally Found My Way» с альбома «Psycho Circus» был третьим по счёту и выпущен в ноябре 1998 года. «I Finally Found My Way» — пронзительная, эмоционально заряженная баллада, которая раскрывает новую грань мощи KISS. Это не просто трек, а исповедь души, облечённая в роскошную музыкальную форму. Песня доказывает, что KISS умеют быть не только громогласными, но и глубоко лиричными. Жанровый стиль: Жанр: симфоническая баллада, хард‑рок с элементами арена‑рока. Участники записи и их вклад: Питер Крисс (Peter Criss) — вокал — его проникновенное исполнение, с фирменным акцентом на эмоциональную подачу лирики, наполняет трек подлинной искренностью; Пол Стэнли (Paul Stanley) — акустическая гитара, бэк-вокал, главный автор песни — создаёт тёплое, мелодичное сопровождение, которое стало основой для лиричной баллады. Он поддержал вокал Крисса гармоничными бэк-вокальными партиями; Bruce Kulick (Брюс Кулик) — бас‑гитара — звучит ровно и мягко, с ритмом и поддержкой вокала Крисса, создавая устойчивый грув и гармоническую основу для мелодии; Кевин Валентайн (Kevin Valentine) — ударные — чёткая, сдержанная игра подчёркивает драматизм песни, не отвлекая от вокала; Шелли Берг (Shelly Berg) — акустическое пианино, оркестровка, дирижёр. Роскошные фортепианные линии и оркестровые аранжировки превращают балладу в лаконичную, изящную симфонию; Боб Эзрин (Bob Ezrin) — Fender Rhodes (электрическое пианино), соавтор песни. Его клавишные переливы добавляют треку атмосферности и глубины. Сам Стэнли рассказывал, что работал над песней вместе с продюсером Эзрином. Они целенаправленно писали композицию, которая бы идеально подошла голосу и стилю Крисса. Стэнли вспоминал, что Крисс, услышав демоверсию с его собственным вокалом, тщательно разучил партию и, в свою очередь, серьёзно отнёсся к записи, стараясь исполнить партию как можно лучше. «I Finally Found My Way» стала своеобразным духовным преемником «Beth» (1976) — ещё одной знаковой хитовой балладой, где Крисс выступил вокалистом. Безупречное качество звука: чистый вокал, детально проработанные инструменты, гармоничное сведение. Оркестровка звучит естественно, не затмевая основной вокал. Промо-сингл «I Finally Found My Way» группы KISS добился заметного успеха: он активно ротировался на радиостанциях в США и Европе, завоевав сердца как поклонников группы, так и любителей рок-баллад. Появившись в альбоме- реюньоне KISS «Psycho Circus», известных как агрессивные исполнители, баллада «I Finally Found My Way» стала настоящим приятным сюрпризом. Успех сингла помог альбому «Psycho Circus» показать сильные результаты: занять — 3 место в Billboard 200 США, 2 место в Rock & Metal Singles Chart и Rock & Metal Albums Chart Великобритании и попасть в топ‑5 национальных чартов большинства стран Европы. Итог: Промо-сингл «I Finally Found My Way» — это гимн обретённой надежды, раскрывающий KISS с эмоциональной стороны. Эта прекрасная баллада обладает всеми ингредиентами настоящего хита: сильным вокалом Питера Крисса, запоминающейся мелодией, эмоциональной глубиной и универсальным посланием. «I Finally Found My Way» заняла почётное место в истории рок‑баллад и стала ещё одной знаковой композицией в дискографии KISS — важной частью наследия группы, демонстрируя её способность к эмоциональной глубине. Тем более, для поклонников группы, она уже является духовным преемником «Beth», и это мнение более чем оправдано. Оригинал остаётся эталоном, который не нуждается в радио‑редакции для расширения аудитории. Этот сингл — провозглашение: KISS по‑прежнему на вершине, их лиричная энергия не угасла, а талант — непревзойдён! <svg class='smile smile-kiss-2' style='width:24px;height:24px;vertical-align:text-bottom;' aria-hidden='true' focusable='false'><use xlink:href='/images/smiles.svg#smile-kiss-2'></use></svg> <svg class='smile smile-tongue-4' style='width:24px;height:24px;vertical-align:text-bottom;' aria-hidden='true' focusable='false'><use xlink:href='/images/smiles.svg#smile-tongue-4'></use></svg></p>
                    </div>
                </a>
                <a class="flex items-center gap-3 py-2 rounded px-1 transition-colors hover:bg-surface-secondary" href="/release/kirpichi-summertime-2013-388997#messages">
